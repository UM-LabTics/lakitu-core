# .env.example
# Copy to .env and fill in real values. Never commit .env.
# Values marked [docker-compose override] are replaced in docker-compose.yml
# during local development — set them here for production/CI use.

# ── AWS credentials ───────────────────────────────────────────────────────────
# In production on EC2, use an IAM role instead and leave these unset.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-2

# ── IoT Core ──────────────────────────────────────────────────────────────────
# Endpoint: AWS Console → IoT Core → Domain configurations (Domain name)
IOT_ENDPOINT=xxxxxxxxxxxx-ats.iot.us-east-2.amazonaws.com
IOT_TOPIC=parking/topic
IOT_CLIENT_ID=id-here
IOT_CERT_PATH=./secrets/device.crt
IOT_KEY_PATH=./secrets/device.key

# ── SQS ───────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/ACCOUNT_ID/queue-name
# How often the backend polls SQS (seconds). Lower = more responsive, more API calls.
SQS_POLL_INTERVAL_SECONDS=2
# Messages pulled per poll cycle (max 10, SQS hard limit).
SQS_MAX_MESSAGES=10

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=bucket-name
NEXT_PUBLIC_S3_BUCKET_NAME=bucket-name

# ── RDS (PostgreSQL) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://parking:password@rds-endpoint.rds.amazonaws.com:5432/parking

# ── Redis ─────────────────────────────────────────────────────────────────────
# [docker-compose override] In local dev this is always redis://redis:6379/0 (the local container).
#REDIS_URL=redis://elasticache-endpoint:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=263520  # 6 months

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development    # development | production
LOG_LEVEL=debug            # debug | info | warning | error

# ── Pi mock behaviour ─────────────────────────────────────────────────────────
# MESSAGE_COUNT=0 lo deja mandando mensajes constantemente; cualquier otro int positivo es la cantidad de mensajes a mandar.
MESSAGE_COUNT=5
SEND_INTERVAL_SECONDS=5
NUM_SPOTS=12
PARKING_ID=mock-01
PARKING_NAME=Mock-Parking-Lot